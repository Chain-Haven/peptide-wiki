NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical production origin (no trailing slash). Used for sitemap, robots,
# canonical URLs, Open Graph, and structured data. Falls back to
# https://peptide-wiki.org when unset.
NEXT_PUBLIC_SITE_URL=https://peptide-wiki.org

# Search engine verification (optional). Paste the token value only.
# Google Search Console → Settings → Ownership verification → HTML tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools verification token (optional).
NEXT_PUBLIC_BING_SITE_VERIFICATION=
